# ── PegaPal — Environment Variables ──
# Copy this file to .env and fill in at least one API key.

# ── LLM API Keys (at least one required) ──
# Groq (free) — get yours at https://console.groq.com
GROQ_API_KEY=

# Claude (optional) — https://console.anthropic.com
ANTHROPIC_API_KEY=

# Google Gemini (free) — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# OpenAI (optional) — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── Defaults ──
# Which LLM to use: "groq", "claude", "gemini", or "openai"
LLM_BACKEND=groq

# Embedding backend: "tfidf" (recommended, zero deps) or "sbert" or "ollama"
EMBEDDING_BACKEND=tfidf

# Admin password for community upload approvals
ADMIN_PASSWORD=changeme

# Ollama server URL (only if EMBEDDING_BACKEND=ollama)
OLLAMA_BASE_URL=http://localhost:11434
