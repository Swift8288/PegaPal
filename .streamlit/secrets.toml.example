# PegaPal — Streamlit Cloud Secrets
# On Streamlit Cloud: Settings > Secrets > paste these contents
# Locally: copy to .streamlit/secrets.toml

# At least one LLM key required
GROQ_API_KEY = ""
ANTHROPIC_API_KEY = ""
GEMINI_API_KEY = ""
OPENAI_API_KEY = ""

# Defaults
LLM_BACKEND = "claude"
EMBEDDING_BACKEND = "tfidf"

# Admin password for community uploads
ADMIN_PASSWORD = "changeme"
